# Public GitHub EUPL-1.2 mirror target (SSH). The script defaults to this value,
# so setting the variable is optional unless the owner/name changes.
# CI auth is NOT via this URL: add a Pipelines SSH key in Bitbucket and register its
# public half as a WRITE deploy key on the GitHub repo (see docs/adr/0002).
GITHUB_MIRROR_URL=git@github.com:AlchemicFlare/zbrett.git
