# Secured Bitbucket repository variables for the public GitHub EUPL-1.2 mirror (SSH).
#
# GITHUB_DEPLOY_KEY: the PRIVATE half of an ED25519 deploy key, base64-encoded
#   (single line). Its PUBLIC half is a WRITE deploy key on the GitHub repo.
#   Generate:  ssh-keygen -t ed25519 -f zbrett-mirror -N ""
#   Encode:    base64 -w0 zbrett-mirror        (PowerShell equivalent in the docs)
GITHUB_DEPLOY_KEY=BASE64_OF_ED25519_PRIVATE_KEY
#
# Optional override (script already defaults to this):
GITHUB_MIRROR_URL=git@github.com:AlchemicFlare/zbrett.git
